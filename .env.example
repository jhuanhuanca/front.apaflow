# Regla: mismo hostname en barra de direcciones y en VITE_API_BASE_URL (localhost+localhost o 127+127).
# Producción: copiar .env.production.example → .env.production y ejecutar npm run build
VITE_API_BASE_URL=http://localhost:8000
VITE_SITE_URL=http://localhost:5173
VITE_DEV_HOST=localhost
VITE_DEV_PORT=5173

# Alternativa todo 127.0.0.1 (abre la SPA solo en http://127.0.0.1:5173):
# VITE_API_BASE_URL=http://127.0.0.1:8000
# VITE_DEV_HOST=127.0.0.1
